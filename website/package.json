{
  "name": "lifesolver-website",
  "version": "1.0.0",
  "description": "LifeSolver Multilithic Web App",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:frontend & npm run dev:backend",
    "dev:full": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && vite",
    "dev:backend": "wrangler pages dev frontend/dist",
    "build": "cd frontend && vite build",
    "deploy": "npm run build && wrangler pages deploy frontend/dist",
    "lint": "cd frontend && eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "cd frontend && vite preview"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-context-menu": "^2.3.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-hover-card": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-menubar": "^1.1.18",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@radix-ui/react-toggle": "^1.1.12",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-oauth/google": "^0.12.1",
    "@tanstack/react-query": "^5.28.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.0",
    "input-otp": "^1.4.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.358.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "react": "^18.2.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.4",
    "react-hook-form": "^7.80.0",
    "react-is": "^19.2.7",
    "react-resizable-panels": "^4.12.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^3.9.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240320.1",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "wrangler": "^3.0.0"
  }
}
