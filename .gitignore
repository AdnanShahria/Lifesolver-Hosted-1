# ============================================
# LifeSolver Monorepo — Root .gitignore
# ============================================

# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/
dev-dist/
build/
.output/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Editor & IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
.env.*.local

# Vite cache
.vite/

# Vercel
.vercel/

# Turbo (if added later)
.turbo/

# Chrome Extension build artifacts
apps/extension/dist/

# Agent tooling
# .agent

# Scripts
setup_git.ps1

# Archives (should not be committed)
*.rar
*.zip
*.7z
